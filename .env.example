# =============================================================================
# LUMIN ART – Environment Variables
# Copy to .env.local for local dev. For Vercel: add these in Project Settings > Environment Variables
# =============================================================================

# Site URL (REQUIRED in production for SEO, sitemap, canonical URLs, Open Graph)
# Vercel auto-sets VERCEL_URL; override with your custom domain for production
# NEXT_PUBLIC_SITE_URL=https://luminart.com

# MongoDB Atlas (database for catalogues + blog)
# Create free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/
MONGODB_DB=luminart

# Cloudflare R2 (file storage for PDFs + cover images)
# Create bucket at https://dash.cloudflare.com → R2
# 1. Create bucket
# 2. Enable Public access (r2.dev or custom domain)
# 3. Create API token (Object Read & Write)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev

# Resend (contact form email)
# Sign up at https://resend.com - 100 emails/day free
# For production: verify your domain and set RESEND_FROM_EMAIL
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
CONTACT_EMAIL=contact@luminart.com

# Admin Portal (/admin)
ADMIN_EMAIL=admin@luminart.com
# Option A - Plain password (dev only; NOT for production)
ADMIN_PASSWORD=admin123
# Option B - Hashed password (production): node scripts/generate-admin-hash.js yourpassword
# ADMIN_PASSWORD_HASH=your-bcrypt-hash

# JWT for admin sessions (REQUIRED in production – use a strong random string)
JWT_SECRET=change-in-production
